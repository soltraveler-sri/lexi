NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=
DATABASE_URL=

# Optional server-side AI fallback. If set, users without a personal BYOK key in
# Settings can still use AI features (calls are billed to the operator and
# tracked as ownership=app in usage_events).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Either "anthropic" or "openai". Defaults to anthropic when unset.
LEXI_DEFAULT_AI_PROVIDER=

# Comma-separated list of email addresses that bypass the conservative MVP
# rate limits when AI calls fall back to the operator's API keys above.
LEXI_RATE_LIMIT_ALLOWLIST_EMAILS=
